# IBDock — .gitignore

# ── Runtime config (contains local machine paths) ─────────────────────────────
IBDock_config.json

# ── IBDock output folders generated at runtime ────────────────────────────────
prepared/
docked/
results/
grid/
logs/

# ── Common docking file formats ───────────────────────────────────────────────
*.pdbqt
*.log
*.dlg

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/

# ── Jupyter (if any notebooks added later) ────────────────────────────────────
.ipynb_checkpoints/

